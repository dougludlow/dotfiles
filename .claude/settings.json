{
	"defaultMode": "acceptEdits",
	"permissions": {
		"deny": [
			"Read(**/.env*)",
			"Read(**/.dev.vars*)",
			"Read(**/*.pem)",
			"Read(**/*.key)",
			"Read(**/secrets/**)",
			"Read(**/credentials/**)",
			"Read(**/.aws/**)",
			"Read(**/.ssh/**)",
			"Read(**/config/database.yml)",
			"Read(**/config/credentials.json)",
			"Read(**/.npmrc)",
			"Read(**/.pypirc)",
			"Write(**/.env*)",
			"Write(**/secrets/**)",
			"Write(**/.ssh/**)"
		],
		"allow": [
			"Read",
			"Glob",
			"Grep",
			"LS",
			"Edit",
			"MultiEdit",
			"Bash(cat *)",
			"Bash(cd *)",
			"Bash(find *)",
			"Bash(gh pr create *)",
			"Bash(git *)",
			"Bash(git commit:*)",
			"Bash(grep *)",
			"Bash(head *)",
			"Bash(ls *)",
			"Bash(node *)",
			"Bash(npm *)",
			"Bash(npx jest *)",
			"Bash(npx nx *)",
			"Bash(nx *)",
			"Bash(pnpm *)",
			"Bash(python3 *)",
			"Bash(tail *)"
		]
	}
}
