prefix_rule(pattern=["./scripts/nx-agent.sh", "lint"], decision="allow")
prefix_rule(pattern=["scripts/nx-agent.sh", "lint"], decision="allow")
prefix_rule(
    pattern=["./scripts/nx-agent.sh", "run"],
    decision="allow",
    match=[
        "./scripts/nx-agent.sh run clients-feature-integrations-ui:tests",
        "./scripts/nx-agent.sh run clients-feature-integrations-ui:run-tests"
    ]
)
prefix_rule(
    pattern=["scripts/nx-agent.sh", "run"],
    decision="allow",
    match=[
        "scripts/nx-agent.sh run clients-feature-integrations-ui:tests",
        "scripts/nx-agent.sh run clients-feature-integrations-ui:run-tests"
    ]
)
prefix_rule(pattern=["./scripts/nx-agent.sh", "test"], decision="allow")
prefix_rule(pattern=["scripts/nx-agent.sh", "test"], decision="allow")
prefix_rule(pattern=["docker", "compose"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(
    pattern=["git", "push"],
    decision="allow",
    match=[
        "git push -u origin HEAD"
    ],
    not_match=[
        "git push -f",
        "git push --force",
    ]
)
prefix_rule(pattern=["git", "stash", "pop"], decision="allow")
prefix_rule(pattern=["git", "stash", "push"], decision="allow")
prefix_rule(pattern=["git", "switch"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["pnpm", "eslint"], decision="allow")
prefix_rule(pattern=["pnpm", "jest"], decision="allow")
