[user]
	name = Doug Ludlow
	email = doug.ludlow@gmail.com
	signingkey = 688F84E9202AA6E9
[core]
	editor = vim
	autocrlf = input
[commit]
	gpgsign = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[pull]
	rebase = true
[fetch]
    prune = true
[worktree]
    guessRemote = true
[alias]
	# Stash everything, freshen the checkout, then restage current changes.
	ready = "!git stash -u && git fresh && git stash pop && git add ."
	# Fetch and prune, go home, rebase main when on main, then clean merged branches.
	fresh = "!git fetch --prune && git home && case \"$(git branch --show-current)\" in main) git pull --rebase origin main ;; esac && git cleanup"
	# Switch home: main in the main checkout, detached main in worktrees.
	home = "!if git rev-parse --git-path HEAD | grep -q '/worktrees/'; then git switch --detach main; else git switch main; fi"
	# Delete merged local branches except main.
	cleanup = "!git fetch --prune && git for-each-ref --format='%(refname:short)' --merged HEAD refs/heads | grep -vx main | xargs git branch -d"
	# Amend the last commit without changing its message.
	fold = commit --amend --no-edit
	# Rebase the current branch onto origin/main, then force-push it.
	update = "!git pull origin main && git push --force-with-lease"
	# Discard all tracked and untracked changes.
	nevermind = !git reset --hard HEAD && git clean -d -f
[credential]
	helper = osxkeychain
[init]
	defaultBranch = main
[gpg]
	program = /opt/homebrew/bin/gpg
[pager]
	branch = false
[stash]
	showIncludeUntracked = true
