{
	"dotfiles.repository": "dougludlow/dotfiles",

	"window.restoreFullscreen": true,
	"window.newWindowDimensions": "fullscreen",

	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"editor.guides.bracketPairs": true,
	"editor.bracketPairColorization.enabled": true,
	"editor.gotoLocation.multipleDefinitions": "goto",
	"editor.rulers": [80, 120],
	"editor.renderWhitespace": "all",
	"editor.formatOnSave": true,
	// "editor.fontFamily": "MonoLisa,Symbols Nerd Font Mono",
	// "editor.fontLigatures": "'calt' on, 'liga' on, 'zero' on, 'ss01' on, 'ss02' on, 'ss03' on, 'ss07' on, 'ss08' on, 'ss11' on",
	"editor.fontFamily": "Maple Mono NF, Jetbrains Mono, Menlo, Consolas, monospace",
	// "editor.fontLigatures": "'calt', 'cv01', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'ss11', 'zero',",
	"editor.fontLigatures": "'calt', 'cv01', 'zero',",
	"editor.suggest.showMethods": true,
	"editor.suggest.preview": true,
	"editor.acceptSuggestionOnEnter": "on",
	"editor.snippetSuggestions": "top",
	"editor.inlineSuggest.enabled": true,

	"diffEditor.ignoreTrimWhitespace": false,

	"javascript.updateImportsOnFileMove.enabled": "always",
	"typescript.updateImportsOnFileMove.enabled": "always",

	"git.enableCommitSigning": true,
	"git.ignoreRebaseWarning": true,
	"git.confirmSync": false,
	"git.autofetch": true,

	"gitlens.plusFeatures.enabled": false,

	"github.copilot.nextEditSuggestions.enabled": true,
	"github.copilot.nextEditSuggestions.fixes": true,

	"prettier.printWidth": 120,
	"prettier.useTabs": true,
	"prettier.singleQuote": true,
	"prettier.semi": true,

	"[csharp]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.insertSpaces": false
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[javascript]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[ruby]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[typescript]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[typescriptreact]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[yaml]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[snowflake-sql]": {
		"editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc",
		"editor.tabSize": 2
	},
	"[shellscript]": {
		"editor.defaultFormatter": "foxundermoon.shell-format",
		"editor.tabSize": 2
	},

	"aws.codeWhisperer.includeSuggestionsWithCodeReferences": false,
	"aws.telemetry": false,
	"aws.experiments": {
		"CodeWhisperer": false
	},
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.enabled": true,
	"workbench.colorTheme": "Night Owl",
	"database-client.autoSync": true,

	"snowflake.connectionsConfigFile": "/Users/doug.ludlow/.snowflake/connections.toml",
	"workbench.editor.empty.hint": "hidden",
	"[sql]": {
		"editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc"
	},
	"datadog.staticAnalysis.notification.suppressOnboarding": true,
	"[xml]": {
		"editor.defaultFormatter": "redhat.vscode-xml"
	},
	"typescript.experimental.useTsgo": true,
	"chat.tools.terminal.outputLocation": "chat",
	"chat.viewSessions.orientation": "stacked",
	"workbench.secondarySideBar.defaultVisibility": "visible",
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	"workbench.editorAssociations": {
		"git-rebase-todo": "default"
	},
	"chat.viewSessions.enabled": false,
	"workbench.panel.defaultLocation": "right"
}
