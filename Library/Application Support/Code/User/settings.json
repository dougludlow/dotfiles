{
	"dotfiles.repository": "dougludlow/dotfiles",

	"window.restoreFullscreen": true,
	"window.newWindowDimensions": "fullscreen",

	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		".env": ".env.*",
		".prettierrc": ".prettierignore",
		".swcrc": "*.swcrc",
		"*.ts": "${capture}.spec.ts, ${capture}.spec.tsx",
		"*.tsx": "${capture}.spec.ts, ${capture}.spec.tsx, ${capture}.stories.tsx",
		"AGENTS.md": "AGENTS.*.md, CLAUDE.md, GEMINI.md",
		"base.vite.config.ts": "vitest.workspace.ts",
		"docker-compose.yml": "docker-compose.*.yml",
		"jest.config.cts": "jest.*.cjs",
		"jest.config.ts": "jest.*.cjs",
		"nx.json": ".nxignore",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc, .nvmrc",
		"prisma.config.ts": "prisma-*.config.ts",
		"settings.json": "settings.*.json",
		"tsconfig.json": "tsconfig.*.json",
		"vite.config.ts": "vitest.setup.ts"
	},

	"workbench.colorTheme": "Night Owl",
	"workbench.editor.empty.hint": "hidden",
	"workbench.editorAssociations": {
		"git-rebase-todo": "default"
	},
	"workbench.panel.defaultLocation": "right",
	"workbench.secondarySideBar.defaultVisibility": "hidden",

	"chat.tools.terminal.outputLocation": "chat",
	"chat.viewSessions.orientation": "stacked",
	"chat.viewSessions.enabled": false,
	"chatgpt.openOnStartup": false,

	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"editor.guides.bracketPairs": true,
	"editor.bracketPairColorization.enabled": true,
	"editor.gotoLocation.multipleDefinitions": "goto",
	"editor.rulers": [80, 120],
	"editor.renderWhitespace": "all",
	"editor.formatOnSave": true,
	"editor.fontFamily": "Maple Mono NF, Jetbrains Mono, Menlo, Consolas, monospace",
	"editor.fontLigatures": "'calt', 'cv01', 'zero',",
	"editor.suggest.showMethods": true,
	"editor.suggest.preview": true,
	"editor.acceptSuggestionOnEnter": "on",
	"editor.snippetSuggestions": "top",
	"editor.inlineSuggest.enabled": true,

	"diffEditor.ignoreTrimWhitespace": false,

	"js/ts.updateImportsOnFileMove.enabled": "always",
	"js/ts.experimental.useTsgo": true,

	"git.enableCommitSigning": true,
	"git.ignoreRebaseWarning": true,
	"git.confirmSync": false,
	"git.autofetch": true,

	"gitlens.plusFeatures.enabled": false,
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",

	"github.copilot.nextEditSuggestions.enabled": true,
	"github.copilot.nextEditSuggestions.fixes": true,

	"prettier.printWidth": 120,
	"prettier.useTabs": true,
	"prettier.singleQuote": true,
	"prettier.semi": true,

	"[csharp]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.insertSpaces": false
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[javascript]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[ruby]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[typescript]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[typescriptreact]": {
		"editor.tabSize": 3,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[yaml]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2
	},
	"[snowflake-sql]": {
		"editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc",
		"editor.tabSize": 2
	},
	"[shellscript]": {
		"editor.defaultFormatter": "foxundermoon.shell-format",
		"editor.tabSize": 2
	},
	"[sql]": {
		"editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc"
	},
	"[xml]": {
		"editor.defaultFormatter": "redhat.vscode-xml"
	},

	"aws.codeWhisperer.includeSuggestionsWithCodeReferences": false,
	"aws.telemetry": false,
	"aws.experiments": {
		"CodeWhisperer": false
	},

	"datadog.staticAnalysis.notification.suppressOnboarding": true,

	"snowflake.connectionsConfigFile": "/Users/doug.ludlow/.snowflake/connections.toml",
	"security.promptForLocalFileProtocolHandling": false
}
